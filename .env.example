# Omnisearch MCP — Environment Variables
# Secrets are managed via Doppler, NOT .env files.
# This file exists purely as documentation of required/optional env vars.
#
# Sync to Cloudflare Workers:
#   doppler secrets download --no-file --format json | npx wrangler secret bulk
#
# Deploy:
#   CLOUDFLARE_EMAIL=$(doppler secrets get CLOUDFLARE_EMAIL --plain) \
#   CLOUDFLARE_API_KEY=$(doppler secrets get CLOUDFLARE_API_TOKEN --plain) \
#   npx wrangler deploy

# ─── Search Providers (web_search tool) ─────────────────────────────
# At least one is required for the web_search tool to work.
TAVILY_API_KEY=
BRAVE_API_KEY=
KAGI_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=
LINKUP_API_KEY=
FIRECRAWL_API_KEY=
YOU_API_KEY=

# ─── AI Response Providers (answer tool) ────────────────────────────
# At least one is required for the answer tool to work.
# Note: PERPLEXITY, KAGI, EXA, BRAVE, TAVILY, YOU keys are shared
# between search and AI response — a single key enables both.
PERPLEXITY_API_KEY=
BRAVE_ANSWER_API_KEY=

# ─── LLM Search (ChatGPT/Claude/Gemini via OpenAI-compatible endpoint) ─
LLM_SEARCH_BASE_URL=
# Optional model overrides (defaults: codex/gpt-5.4, claude/haiku, gemini/search-fast)
# LLM_SEARCH_CHATGPT_MODEL=
# LLM_SEARCH_CLAUDE_MODEL=
# LLM_SEARCH_GEMINI_MODEL=

# ─── Gemini Grounded (native Gemini API with URL context) ────────
GEMINI_GROUNDED_API_KEY=
# GEMINI_GROUNDED_MODEL=

# ─── Fetch Providers (fetch tool) ─────────────────────────────────
# At least one is required for the fetch tool to work.
# Note: TAVILY, FIRECRAWL, YOU, LINKUP keys are shared with search —
# a single key enables both search and fetch for that provider.
JINA_API_KEY=
BRIGHT_DATA_API_KEY=
# BRIGHT_DATA_ZONE=unblocker
DIFFBOT_TOKEN=
SOCIAVAULT_API_KEY=
SPIDER_CLOUD_API_TOKEN=
SCRAPFLY_API_KEY=
SCRAPEGRAPHAI_API_KEY=
SCRAPE_DO_API_TOKEN=
SCRAPELESS_API_KEY=
OPENGRAPH_IO_API_KEY=
SCRAPINGBEE_API_KEY=
SCRAPERAPI_API_KEY=
ZYTE_API_KEY=
SCRAPINGANT_API_KEY=
OXYLABS_WEB_SCRAPER_USERNAME=
OXYLABS_WEB_SCRAPER_PASSWORD=
OLOSTEP_API_KEY=
# Must be base64-encoded username:password (echo -n 'user:pass' | base64)
DECODO_WEB_SCRAPING_API_KEY=
SCRAPPEY_API_KEY=
LEADMAGIC_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
# Reused from global Cloudflare config (also used by wrangler deploy):
# CLOUDFLARE_EMAIL=
# CLOUDFLARE_API_KEY=

# ─── Fetch Retry/Timeout Tuning (optional) ───────────────────────
# FETCH_MAX_RETRIES=2
# FETCH_RETRY_MIN_TIMEOUT_MS=1000
# FETCH_RETRY_MAX_TIMEOUT_MS=5000
# FETCH_TIMEOUT_MS=30000

# ─── REST Endpoints Auth (optional) ───────────────────────────────
OPENWEBUI_API_KEY=
OMNISEARCH_API_KEY=
