# Omnisearch MCP — Environment Variables
# Secrets are managed via Doppler, NOT .env files.
# This file exists purely as documentation of required/optional env vars.
#
# Sync to Cloudflare Workers:
#   doppler secrets download --no-file --format json | npx wrangler secret bulk
#
# Deploy:
#   CLOUDFLARE_EMAIL=$(doppler secrets get CLOUDFLARE_EMAIL --plain) \
#   CLOUDFLARE_API_KEY=$(doppler secrets get CLOUDFLARE_API_TOKEN --plain) \
#   npx wrangler deploy

# ─── Search Providers (web_search tool) ─────────────────────────────
# At least one is required for the web_search tool to work.
TAVILY_API_KEY=
BRAVE_API_KEY=
KAGI_API_KEY=
EXA_API_KEY=
SERPAPI_API_KEY=
LINKUP_API_KEY=
FIRECRAWL_API_KEY=
YOU_API_KEY=

# ─── AI Response Providers (answer tool) ────────────────────────────
# At least one is required for the answer tool to work.
# Note: PERPLEXITY, KAGI, EXA, BRAVE, TAVILY, YOU keys are shared
# between search and AI response — a single key enables both.
PERPLEXITY_API_KEY=
BRAVE_ANSWER_API_KEY=

# ─── LLM Search (ChatGPT/Claude/Gemini via OpenAI-compatible endpoint) ─
LLM_SEARCH_BASE_URL=
# Optional model overrides (defaults: codex/gpt-5.4, claude/haiku, gemini/search-fast)
# LLM_SEARCH_CHATGPT_MODEL=
# LLM_SEARCH_CLAUDE_MODEL=
# LLM_SEARCH_GEMINI_MODEL=

# ─── Gemini Grounded (native Gemini API with URL context) ────────
GEMINI_GROUNDED_API_KEY=
# GEMINI_GROUNDED_MODEL=

# ─── REST /search Auth (optional) ──────────────────────────────────
OPENWEBUI_API_KEY=
OMNISEARCH_API_KEY=
