# Template for wrangler.toml — copy to `wrangler.toml` (gitignored) and fill in
# the deploy route. The real wrangler.toml is intentionally NOT committed because
# its custom-domain route is an unauthenticated endpoint.
#
#   cp wrangler.toml.example wrangler.toml
#   # then either keep workers_dev = true (uses *.workers.dev) OR add a [[routes]] block
#
name = "omnisearch-mcp"
main = "src/worker.ts"
compatibility_date = "2026-06-20"
compatibility_flags = ["nodejs_compat"]
workers_dev = false

# Smart Placement — co-locate the Worker near its (mostly US-based) provider
# backends so each of the 6 simultaneous outbound connections completes faster,
# freeing connection slots sooner on the fanout/grounding paths.
[placement]
mode = "smart"

[observability]
enabled = true

[observability.traces]
enabled = true
destinations = ["grafana"]

[observability.logs]
enabled = true
destinations = ["grafana-logs"]

[[durable_objects.bindings]]
name = "OmnisearchMCP"
class_name = "OmnisearchMCP"

[[kv_namespaces]]
binding = "CACHE"
id = "d8b1130bed234c308a15316a5dfc15a8"

[[r2_buckets]]
binding = "TRACE_BUCKET"
bucket_name = "omnisearch"

# Analytics Engine — cheap queryable time-series layer (trends / percentiles /
# per-provider health over time). Complements R2 traces (full-fidelity per-request
# forensics). One writeDataPoint() = one billed data point; packing more dimensions
# into a single call is free. Three datasets so the high-rate fetch stream samples
# independently (sampling is per-index) while low-volume search/answer stay at 100%.
[[analytics_engine_datasets]]
binding = "AE_REQUESTS"
dataset = "omni_requests"

[[analytics_engine_datasets]]
binding = "AE_SEARCH"
dataset = "omni_search"

[[analytics_engine_datasets]]
binding = "AE_FETCH"
dataset = "omni_fetch"

# Custom-domain route — uncomment and set your own host (kept out of the public
# repo for the deployed instance). Alternatively set workers_dev = true above.
# [[routes]]
# pattern = "your-host.example.com/*"
# zone_name = "example.com"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["OmnisearchMCP"]
